pkgname=dot-ddns
pkgver=0.1.0
pkgrel=1
pkgdesc="Dynamic DNS-over-TLS updater for systemd-resolved"
arch=('x86_64' 'aarch64')
url="https://github.com/OliverMarcusson/dot-ddns"
license=('MIT')
depends=('systemd' 'networkmanager')
makedepends=('cargo')
source=()
sha256sums=()

build() {
  cargo build --release --locked
}

package() {
  install -Dm755 target/release/dot-ddns "$pkgdir/usr/bin/dot-ddns"
  install -Dm644 packaging/dot-ddns.service "$pkgdir/usr/lib/systemd/system/dot-ddns.service"
  install -Dm644 packaging/dot-ddns.tmpfiles "$pkgdir/usr/lib/tmpfiles.d/dot-ddns.conf"
  install -Dm644 packaging/config.example.toml "$pkgdir/usr/share/doc/dot-ddns/config.example.toml"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/dot-ddns/LICENSE"
}
